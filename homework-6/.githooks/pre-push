#!/usr/bin/env bash
# Pre-push hook: runs test coverage check and blocks push if below 80%

PROJECT_DIR="/home/vtkach/Projects/Studying/ai-training/AI-Coding-Partner-Homework/homework-6"

echo ""
echo "========================================"
echo "  Pre-push Coverage Check"
echo "========================================"
echo ""

cd "$PROJECT_DIR" || { echo "ERROR: Cannot cd to $PROJECT_DIR"; exit 1; }

echo "Running tests with coverage..."
echo ""

npm run test:coverage -- --coverageReporters=text --coverageReporters=json-summary --passWithNoTests
TEST_EXIT=$?

echo ""

if [ $TEST_EXIT -ne 0 ]; then
  echo "========================================"
  echo "  PUSH BLOCKED: Tests failed"
  echo "========================================"
  echo ""
  exit 1
fi

SUMMARY="$PROJECT_DIR/coverage/coverage-summary.json"
if [ ! -f "$SUMMARY" ]; then
  echo "========================================"
  echo "  PUSH BLOCKED: coverage-summary.json not found"
  echo "========================================"
  echo ""
  exit 1
fi

PCT=$(jq -r '.total.lines.pct // 0' "$SUMMARY" 2>/dev/null || echo "0")
# Jest outputs "Unknown" when there are zero source lines (no tests); treat as 0
[[ "$PCT" == "null" || "$PCT" == "Unknown" || -z "$PCT" ]] && PCT="0"

echo "Line coverage: ${PCT}%"
echo ""

if awk -v pct="$PCT" 'BEGIN { exit (pct+0 >= 80) ? 0 : 1 }'; then
  echo "========================================"
  echo "  PASSED: ${PCT}% >= 80% — push allowed"
  echo "========================================"
  echo ""
  exit 0
else
  echo "========================================"
  echo "  PUSH BLOCKED: ${PCT}% is below 80%"
  echo "========================================"
  echo ""
  exit 1
fi
